function formatINR(value){
  return `₹${value.toLocaleString('en-IN', { maximumFractionDigits: 0 })}`
}

function Stat({ label, value }){
  return (
    <div className="stat-card">
      <span className="stat-label">{label}</span>
      <strong className="stat-value">{value}</strong>
    </div>
  )
}

export default function Service(){
  const navigate = useNavigate()
  const [cart, setCart] = useState(() => {
    const stored = loadCart()
    return Array.isArray(stored.items) ? stored.items : []
  })
  const [selectedCat, setSelectedCat] = useState(catalog[0].id)
  const [notes, setNotes] = useState('')
  const [query, setQuery] = useState('')
  const [vehicleType, setVehicleType] = useState(sessionStorage.getItem('rw_vehicle_type') || 'Car')

  useEffect(() => {
    saveCart({ items: cart, currency: 'INR' })
  }, [cart])

  useEffect(() => {
    sessionStorage.setItem('rw_vehicle_type', vehicleType)
  }, [vehicleType])

  const subtotal = useMemo(() => cart.reduce((sum, item) => sum + (item.price || 0) * (item.qty || 1), 0), [cart])
  const serviceFee = cart.length ? 49 : 0
  const tax = Math.round((subtotal + serviceFee) * 0.05)
  const total = subtotal + serviceFee + tax

  const filteredCatalog = useMemo(() => {
    const q = query.trim().toLowerCase()
    if(!q) return catalog
    return catalog.map(cat => ({
      ...cat,
      items: cat.items.filter(it =>
        it.title.toLowerCase().includes(q) ||
        (it.desc || '').toLowerCase().includes(q)
      )
    })).filter(cat => cat.items.length)
  }, [query])

  const addToCart = (svc) => {
    setCart(prev => {
      const existing = prev.find(i => i.id === svc.id)
      if(existing){
        showSuccess(`Updated quantity for ${svc.title}`)
        return prev.map(i => i.id === svc.id ? { ...i, qty: i.qty + 1 } : i)
      }
      showSuccess(`✓ Added ${svc.title} to cart`)
      return [...prev, { id: svc.id, title: svc.title, price: svc.price, qty: 1, badge: svc.badge }]
    })
  }

  const updateQty = (id, delta) => {
    setCart(prev => prev.map(i => i.id === id ? { ...i, qty: Math.max(1, i.qty + delta) } : i))
  }

  const removeItem = (id) => {
    const item = cart.find(i => i.id === id)
    setCart(prev => prev.filter(i => i.id !== id))
    if(item) showSuccess(`Removed ${item.title} from cart`)
  }

  const clearCart = () => setCart([])

  const proceedCheckout = () => {
    if(!cart.length){
      alert('Cart is empty')
      return
    }
    const payload = {
      items: cart.map(it => ({ ...it, unitPrice: it.price })),
      subtotal,
      serviceFee,
      tax,
      total,
      notes,
      createdAt: Date.now()
    }
    sessionStorage.setItem('rw_checkout', JSON.stringify(payload))
    navigate('/checkout')
  }

  return (
    <div>
      <style>{`
        .svc-hero{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:28px;flex-wrap:wrap;}
        .svc-hero h2{margin:0;font-weight:900;letter-spacing:-0.6px;}
        .svc-hero p{margin:0;color:var(--text-secondary);max-width:600px;}
        .svc-badges{display:flex;gap:8px;flex-wrap:wrap;}
        .svc-grid{display:grid;grid-template-columns:2fr 1fr;gap:22px;align-items:start;}
        @media(max-width:1024px){.svc-grid{grid-template-columns:1fr;}}
        .svc-card{border:1px solid var(--border);border-radius:16px;padding:18px 16px;background:linear-gradient(135deg,#111,#161616);box-shadow:var(--shadow-md);}
        .svc-cat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;margin-bottom:14px;}
        .svc-cat-card{position:relative;overflow:hidden;border-radius:14px;border:1px solid rgba(255,255,255,0.08);cursor:pointer;transition:all .2s;min-height:140px;background:#0f0f0f;}
        .svc-cat-card img{width:100%;height:100%;object-fit:cover;filter:brightness(0.7);transition:all .2s;}
        .svc-cat-card:hover img{filter:brightness(0.9);}
        .svc-cat-overlay{position:absolute;inset:0;padding:14px;display:flex;flex-direction:column;justify-content:space-between;color:#fff;background:linear-gradient(180deg,rgba(0,0,0,0.25),rgba(0,0,0,0.55));}
        .svc-cat-title{font-weight:900;font-size:17px;margin:0;letter-spacing:-0.3px;}
        .svc-cat-sub{font-size:12px;color:#e5e7eb;}
        .svc-cat-active{box-shadow:0 0 0 2px #60a5fa;border-color:#60a5fa;}
        .svc-head{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;}
        .svc-title{font-weight:800;margin:0;letter-spacing:-0.4px;color:#fff;}
        .svc-sub{color:var(--text-secondary);margin-top:4px;font-size:13px;}
        .svc-items{display:grid;gap:12px;margin-top:14px;}
        .svc-item{border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:12px 14px;background:linear-gradient(135deg,#191919,#111);display:grid;gap:6px;box-shadow:0 4px 14px rgba(0,0,0,0.35);}
        .svc-item-top{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;}
        .svc-thumb{width:82px;height:82px;border-radius:10px;object-fit:cover;border:1px solid rgba(255,255,255,0.08);background:#0f0f0f;flex-shrink:0;}
        .svc-item-title{font-weight:800;color:#fff;margin:0;font-size:15px;}
        .svc-item-desc{color:#a0a0a0;font-size:13px;line-height:1.45;margin:0;}
        .svc-meta{display:flex;gap:8px;align-items:center;flex-wrap:wrap;font-size:12px;color:#ccc;}
        .svc-badge{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);padding:6px 10px;border-radius:999px;font-size:11px;font-weight:700;color:#fff;}
        .svc-chip{border:1px solid rgba(255,255,255,0.12);border-radius:999px;padding:6px 12px;font-size:12px;color:#fff;background:rgba(255,255,255,0.05);}
        .svc-stat{border:1px solid rgba(255,255,255,0.12);border-radius:12px;padding:12px 14px;background:linear-gradient(135deg,#161616,#101010);display:grid;gap:4px;}
        .svc-stat-label{color:var(--text-secondary);font-size:12px;}
        .svc-stat-value{color:#fff;font-weight:800;font-size:16px;}
        .price-tag{font-weight:900;color:#fff;font-size:16px;text-align:right;}
        .cart-pane{border:1px solid var(--border);border-radius:16px;padding:18px 16px;background:linear-gradient(135deg,#101010,#161616);position:sticky;top:110px;box-shadow:0 12px 32px rgba(0,0,0,0.45);}
        .cart-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
        .cart-list{display:grid;gap:12px;}
        .cart-row{display:grid;grid-template-columns:1fr auto auto auto;gap:10px;align-items:center;border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:12px;background:linear-gradient(135deg,#181818,#121212);}
        @media(max-width:640px){.cart-row{grid-template-columns:1fr auto;grid-template-areas:'title qty' 'price price';}}
        .cart-row h4{margin:0;color:#fff;font-weight:800;font-size:14px;}
        .qty-btn{width:28px;height:28px;border-radius:8px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.06);color:#fff;font-weight:800;cursor:pointer;}
        .qty-wrap{display:flex;align-items:center;gap:6px;}
        .cart-total-box{border:1px solid rgba(255,255,255,0.12);border-radius:12px;padding:12px 14px;background:linear-gradient(135deg,#1d1d1d,#141414);display:grid;gap:6px;}
        .totals-line{display:flex;justify-content:space-between;font-size:13px;color:#c9c9c9;}
        .totals-line strong{color:#fff;}
        .notes{width:100%;min-height:70px;border-radius:12px;border:1px solid rgba(255,255,255,0.08);background:#131313;color:#fff;padding:10px 12px;font-size:13px;}
      `}</style>

      <div className="svc-hero">
        <div>
          <h2>Services & Pricing</h2>
          <p>Curated packages with transparent pricing. Add items to your cart, review fees and tax instantly, then proceed to checkout.</p>
        </div>
        <div className="svc-badges">
          <span className="svc-badge">🔒 Secure cart</span>
          <span className="svc-badge">⚡ Live dispatch</span>
          <span className="svc-badge">⭐ 4.8 rated partners</span>
          <span className="svc-badge">🛠️ OEM parts</span>
        </div>
      </div>

      <div className="svc-card" style={{marginBottom:12,display:'grid',gap:12}}>
        <div style={{display:'grid',gridTemplateColumns:'2fr 3fr',gap:12,alignItems:'center'}}>
          <div style={{display:'grid',gap:8}}>
            <div style={{display:'flex',gap:10,flexWrap:'wrap'}}>
              <div className="svc-badge">No hidden charges</div>
              <div className="svc-badge">Upfront estimates</div>
              <div className="svc-badge">Priority emergency slots</div>
            </div>
            <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(120px,1fr))',gap:10}}>
              <Stat label="Avg ETA" value="32 mins" />
              <Stat label="Coverage" value="14 cities" />
              <Stat label="Support" value="24x7" />
              <Stat label="Satisfaction" value="4.8/5" />
            </div>
          </div>
          <div style={{display:'grid',gap:8}}>
            <label className="rw-label" style={{fontWeight:700}}>Search services</label>
            <input
              value={query}
              onChange={e=>setQuery(e.target.value)}
              placeholder="Search by name or symptom (e.g. brake, battery, tow)"
              style={{width:'100%',padding:'12px 14px',borderRadius:12,border:'1px solid rgba(255,255,255,0.08)',background:'#0f0f0f',color:'#fff'}}
            />
            <div style={{display:'flex',alignItems:'center',gap:8}}>
              <label className="rw-label" style={{fontWeight:700,margin:0}}>Vehicle</label>
              <select value={vehicleType} onChange={e=>setVehicleType(e.target.value)}>
                <option>Bike</option>
                <option>Car</option>
                <option>SUV</option>
                <option>EV</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div className="svc-grid">
        <div style={{display:'grid',gap:14}}>
          <div className="svc-cat-grid">
            {(filteredCatalog.length? filteredCatalog : catalog).map(cat => (
              <div key={cat.id} className={`svc-cat-card ${selectedCat===cat.id? 'svc-cat-active': ''}`} onClick={()=>setSelectedCat(cat.id)}>
                <img src={cat.image || heroImages[cat.id]} alt={cat.title} loading="lazy" />
                <div className="svc-cat-overlay">
                  <div>
                    <p className="svc-cat-title">{cat.title}</p>
                    {cat.subtitle && <p className="svc-cat-sub">{cat.subtitle}</p>}
                  </div>
                  <div style={{fontSize:12,opacity:.85}}>{cat.items.length} services</div>
                </div>
              </div>
            ))}
          </div>

          {(filteredCatalog.length? filteredCatalog : catalog).filter(c=>c.id===selectedCat).map(cat => (
            <div key={cat.id} className="svc-card">
              <div className="svc-head">
                <div>
                  <div className="svc-title">{cat.title}</div>
                  {cat.subtitle && <div className="svc-sub">{cat.subtitle}</div>}
                </div>
                <div style={{display:'flex',gap:8,flexWrap:'wrap'}}>
                  <span className="svc-chip">{cat.items.length} options</span>
                  <span className="svc-chip">Photo verified</span>
                </div>
              </div>
              <div className="svc-items">
                {cat.items.map(item => (
                  <div key={item.id} className="svc-item">
                    <div className="svc-item-top">
                      <img className="svc-thumb" src={item.image || heroImages[cat.id]} alt={item.title} loading="lazy" />
                      <div style={{flex:1,minWidth:0}}>
                        <h4 className="svc-item-title">{item.title}</h4>
                        <p className="svc-item-desc">{item.desc}</p>
                        <div className="svc-meta">
                          <span className="svc-chip">⏱️ {item.sla}</span>
                          {item.badge && <span className="svc-chip">{item.badge}</span>}
                          <span className="svc-chip">Upfront pricing</span>
                          <span className="svc-chip">{vehicleType} ready</span>
                        </div>
                      </div>
                      <div style={{textAlign:'right'}}>
                        <div className="price-tag">{formatINR(item.price)}</div>
                        <div style={{display:'flex',gap:8,justifyContent:'flex-end'}}>
                          <Button size="sm" variant="primary" style={{marginTop:8}} onClick={() => addToCart(item)}>Add</Button>
                          <button
                            aria-label="Toggle favorite"
                            onClick={() => {
                              const wasFav = isFavorite(item.id)
                              toggleFavorite({ ...item, category: cat.id })
                              showSuccess(wasFav ? 'Removed from favorites' : 'Added to favorites')
                              window.dispatchEvent(new Event('favoritesUpdated'))
                            }}
                            style={{
                              marginTop:8,
                              padding:'6px 10px',
                              borderRadius:8,
                              border:'1px solid rgba(255,255,255,0.12)',
                              background:'transparent',
                              color:isFavorite(item.id)?'#ef4444':'#e5e7eb',
                              cursor:'pointer',
                              fontWeight:700
                            }}
                          >
                            {isFavorite(item.id) ? '♥' : '♡'}
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

        <aside className="cart-pane">
          <div className="cart-header">
            <div style={{display:'flex',flexDirection:'column',gap:2}}>
              <strong style={{color:'#fff'}}>Your Cart</strong>
              <span style={{color:'var(--text-secondary)',fontSize:12}}>{cart.length ? `${cart.length} item(s)` : 'No items yet'}</span>
            </div>
            <Button size="sm" variant="ghost" onClick={clearCart} disabled={!cart.length}>Clear</Button>
          </div>

          {cart.length === 0 ? (
            <div style={{textAlign:'center',padding:'26px 12px',color:'#888',border:'1px dashed rgba(255,255,255,0.12)',borderRadius:12}}>
              <div style={{fontSize:36,marginBottom:6}}>🛒</div>
              <div style={{fontWeight:700}}>Cart is empty</div>
              <div style={{fontSize:12,marginTop:4}}>Add services to view totals</div>
            </div>
          ) : (
            <div className="cart-list">
              {cart.map(item => (
                <div key={item.id} className="cart-row">
                  <h4>{item.title}</h4>
                  <div className="qty-wrap">
                    <button className="qty-btn" onClick={() => updateQty(item.id,-1)}>–</button>
                    <span style={{color:'#fff',fontWeight:800}}>{item.qty}</span>
                    <button className="qty-btn" onClick={() => updateQty(item.id,1)}>+</button>
                  </div>
                  <div style={{fontWeight:800,color:'#fff'}}>{formatINR(item.price * item.qty)}</div>
                  <button className="qty-btn" aria-label="Remove" onClick={() => removeItem(item.id)}>✕</button>
                </div>
              ))}
            </div>
          )}

          <div className="cart-total-box" style={{marginTop:14}}>
            <div className="totals-line"><span>Subtotal</span><strong>{formatINR(subtotal)}</strong></div>
            <div className="totals-line"><span>Service fee</span><strong>{formatINR(serviceFee)}</strong></div>
            <div className="totals-line"><span>Tax (5%)</span><strong>{formatINR(tax)}</strong></div>
            <div className="totals-line" style={{fontSize:15,fontWeight:800}}><span>Total</span><strong>{formatINR(total)}</strong></div>
          </div>

          <div style={{marginTop:12}}>
            <label className="rw-label">Notes for mechanic</label>
            <textarea className="notes" placeholder="Describe symptoms, location landmarks, or time preference" value={notes} onChange={e=>setNotes(e.target.value)} />
          </div>

          <Button variant="primary" size="md" style={{marginTop:14,width:'100%'}} onClick={proceedCheckout}>Proceed to checkout →</Button>
          <div style={{fontSize:11,color:'var(--text-secondary)',marginTop:8}}>We’ll hold your cart for 60 minutes. Secure payments and transparent estimates on the next step.</div>
        </aside>
      </div>
      {/* Reviews Section */}
      <div style={{maxWidth:'100%',margin:'40px 0',padding:'0 12px'}}>
        <div className="svc-card">
          <Reviews serviceId="repairwale-services" serviceName="RepairWale Services" />
        </div>
      </div>    </div>
  )
}
