      { id: 'tracking', title: 'Live Tracking', desc: 'Mechanic ETA + live location', price: 0, sla: 'Live', badge: 'Free', image: 'https://images.unsplash.com/photo-1503736334956-4c8f8e92946d?auto=format&fit=crop&w=800&q=70' },
