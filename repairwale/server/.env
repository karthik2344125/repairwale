# Razorpay Configuration
# Leave these empty to use MOCK payments (for testing without real API keys)
# To enable live payments, get credentials from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Uncomment and fill these with real credentials for live payments:
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
